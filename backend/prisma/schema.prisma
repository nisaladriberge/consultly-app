datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../node_modules/@prisma/client"
}

// Our Very First Database Model (Table)
model User {
  id        String   @id @default(uuid()) // Automatically generates a unique secure ID
  name      String
  email     String   @unique
  role      String   // Can be "client" or "expert"
  createdAt DateTime @default(now())       // Tracks when the user registered
}